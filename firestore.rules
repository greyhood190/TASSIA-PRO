rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net (Deny all by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable security helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprint for User Profiles
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role', 'isVerified', 'passwordHash', 'createdAt'])
        && data.keys().size() == 7
        && data.id is string
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 120
        && data.role is string
        && data.isVerified is bool
        && data.passwordHash is string && data.passwordHash.size() <= 200
        && data.createdAt is string;
    }

    // 3. Rules for user profiles
    match /users/{userId} {
      // Must be a valid ID structure
      allow get: if isSignedIn() && isValidId(userId);
      
      // Let users read lists of their own profile if required
      allow list: if isSignedIn() && resource.data.id == request.auth.uid;

      // Users can only create their own profile
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && isValidId(userId);

      // Users can only update their own profile and some fields are immutable (like email, id, createdAt)
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && isValidId(userId)
        && incoming().createdAt == existing().createdAt
        && incoming().id == existing().id
        && incoming().email == existing().email;

      // Users cannot be deleted from the client SDK
      allow delete: if false;
    }

    // 4. Rules for shared tournament app state
    match /app_state/{stateId} {
      // Anyone can read the shared tournament database state (standings, matches, fixtures, news, etc.)
      allow get: if isValidId(stateId);
      allow list: if true;

      // Only authenticated users can write/update the state
      allow create, update: if isSignedIn() && isValidId(stateId);
      
      // State cannot be deleted
      allow delete: if false;
    }
  }
}
